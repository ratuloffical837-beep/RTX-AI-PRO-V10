rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ══════════════════════════════════════
    // পুরানো App এর Collections
    // ══════════════════════════════════════

    match /users/{userId} {
      allow read:   if true;
      allow write:  if false;
    }

    match /payments/{txId} {
      allow create: if true;
      allow read:   if false;
      allow update: if false;
      allow delete: if false;
    }

    // ══════════════════════════════════════
    // নতুন App (Master AI) এর Collections
    // ══════════════════════════════════════

    match /master_users/{userId} {
      allow read:   if true;
      allow write:  if false;
    }

    match /master_payments/{txId} {
      allow create: if true;
      allow read:   if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}
